{
	"version": "0.2.1",
	"configurations": [
		{
			"name": "Astro Dev",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"args": ["run", "dev"],
			"env": {
				"NODE_ENV": "development"
			},
			"serverReadyAction": {
				"pattern": "Local\\s+http://localhost:4321",
				"uriFormat": "http://localhost:4321",
				"action": "openExternally"
			}
		}
	]
}
